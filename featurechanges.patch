+    placeholder: "pat-...",
+    helpText: "HubSpot Private App token van https://app.hubspot.com/settings/apps",
+    testEndpoint: "/api/integrations/test/hubspot",
+  },
+  {
+    id: "lusha",
+    name: "Lusha",
