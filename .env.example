# Copy to .env.local for local dev, add same vars in Vercel → Settings → Environment Variables

# All three are required on Vercel (Production + Preview). Redeploy after adding.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional alias for new Supabase secret keys (sb_secret_...):
# SUPABASE_SECRET_KEY=

# Claude API for AI columns (server-side only — never expose to browser)
ANTHROPIC_API_KEY=

# OpenAI API for lead generation (preferred if set — server-side only)
OPENAI_API_KEY=

# HubSpot Private App access token
HUBSPOT_ACCESS_TOKEN=

# Optional enrichment providers (Phase 2b)
HUNTER_API_KEY=
APOLLO_API_KEY=
LUSHA_API_KEY=

# Instantly outreach
INSTANTLY_API_KEY=

# Comma-separated user IDs for nightly cron (fallback if user_settings empty)
NIGHTLY_USER_IDS=demo-user

# Vercel Cron secret for nightly jobs
CRON_SECRET=
