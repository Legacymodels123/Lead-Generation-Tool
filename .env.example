# Company Enrichment Workspace launch template
# Copy to .env.local for local development and mirror the same keys in Vercel.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Company Enrichment Workspace
NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional alias for new secret-key naming
# SUPABASE_SECRET_KEY=

# Auth and session
AUTH_SECRET=
DISABLE_MEMORY_AUTH=
OAUTH_STATE_SECRET=

# Claude (primary AI provider)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional fallback AI provider
OPENAI_API_KEY=

# Enrichment providers
HUNTER_API_KEY=
LUSHA_API_KEY=
APOLLO_API_KEY=

# HubSpot OAuth and sync
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/oauth/callback
HUBSPOT_ACCESS_TOKEN=

# Optional secondary providers / outreach
INSTANTLY_API_KEY=
LINKEDIN_ACCESS_TOKEN=

# Scheduler / background jobs
CRON_SECRET=
NIGHTLY_USER_IDS=

# Import and property intelligence
PROPERTY_INFERENCE_PROVIDER=anthropic
PROPERTY_INFERENCE_MODEL=claude-sonnet-4-20250514
